{
  "expo": {
    "name": "SemaphoreChat",
    "slug": "semaphorechat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.semaphorechat",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.semaphorechat",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Semaphore needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "Semaphore needs microphone access for calls and voice messages."
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Semaphore needs access to your photos to send images."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Semaphore needs access to your microphone for calls and voice messages."
        }
      ],
      "expo-document-picker"
    ],
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "600dd04d-5574-460d-acd7-22541e12ffc1"
      }
    },
  }
}
