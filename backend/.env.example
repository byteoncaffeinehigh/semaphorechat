# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/antares_chat?sslmode=disable

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# Server
PORT=8080
FRONTEND_URL=http://localhost:3000

# Google OAuth (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Web Push / VAPID — generate with:
#   go run -mod=mod github.com/SherClockHolmes/webpush-go/cmd/webpush-go@latest
# or use: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
